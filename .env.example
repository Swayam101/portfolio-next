# MongoDB connection for blog posts
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio

# API key for all /api/blog admin endpoints (send as x-api-key header)
# Used by: GET/POST /api/blog, GET/DELETE /api/blog/[slug],
#          GET /api/blog/raw/[slug], POST /api/blog/validate, GET /api/blog/series
# Also required for the admin panel at /admin
BLOG_API_KEY=your_secret_api_key_here

# Telegram bot for contact form
# 1. Create a bot via @BotFather on Telegram → get token
# 2. Start a chat with your bot, send a message
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to get your chat_id

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
